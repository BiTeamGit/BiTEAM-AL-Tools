{
  "name": "bi-team-al-tools",
  "displayName": "BiTeam AL Tools",
  "description": "Tools for Business Central AL development: sync AI instruction files and update BC versions across workspaces",
  "version": "0.1.0",
  "publisher": "biteam",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Programming Languages", "Other"],
  "keywords": ["AL", "Business Central", "Dynamics 365 BC", "Azure DevOps", "instructions"],
  "icon": "images/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/matthiasrabus/biTeamALInstructions"
  },
  "bugs": {
    "url": "https://github.com/matthiasrabus/biTeamALInstructions/issues"
  },
  "homepage": "https://github.com/matthiasrabus/biTeamALInstructions#readme",
  "activationEvents": [
    "workspaceContains:**/app.json"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "biTeamALTools.download",
        "title": "BIT: Download Instruction Files"
      },
      {
        "command": "biTeamALTools.updateBcVersion",
        "title": "BIT: Update BC Version"
      }
    ],
    "configuration": {
      "title": "BiTeam AL Tools",
      "properties": {
        "biTeamALTools.orgUrl": {
          "type": "string",
          "default": "",
          "description": "Azure DevOps organization URL (e.g. https://dev.azure.com/myorg)"
        },
        "biTeamALTools.project": {
          "type": "string",
          "default": "",
          "description": "Azure DevOps project name"
        },
        "biTeamALTools.repository": {
          "type": "string",
          "default": "",
          "description": "Azure DevOps repository name"
        },
        "biTeamALTools.folders": {
          "type": "array",
          "items": { "type": "string" },
          "default": [".claude", ".github"],
          "description": "Folders to download from the repository root"
        },
        "biTeamALTools.autoDownloadOnOpen": {
          "type": "boolean",
          "default": false,
          "description": "Automatically download instruction files when an AL workspace is opened (BIT: Download Instruction Files). If disabled, trigger the download manually via the Command Palette."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
