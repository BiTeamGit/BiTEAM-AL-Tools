{
  "name": "bi-team-al-tools",
  "displayName": "BiTeam AL Tools",
  "description": "%extension.description%",
  "version": "0.1.6",
  "publisher": "biteam",
  "engines": {
    "vscode": "^1.85.0"
  },
  "l10n": "./l10n",
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "AL",
    "Business Central",
    "Dynamics 365 BC",
    "Azure DevOps",
    "instructions"
  ],
  "icon": "images/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/BiTeamGit/BiTEAM-AL-Tools"
  },
  "bugs": {
    "url": "https://github.com/BiTeamGit/BiTEAM-AL-Tools/issues"
  },
  "homepage": "https://github.com/BiTeamGit/BiTEAM-AL-Tools#readme",
  "activationEvents": [
    "workspaceContains:**/app.json"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "biTeamALTools.download",
        "title": "%command.download.title%"
      },
      {
        "command": "biTeamALTools.updateBcVersion",
        "title": "%command.updateBcVersion.title%"
      },
      {
        "command": "biTeamALTools.updateProjectSettings",
        "title": "%command.updateProjectSettings.title%"
      }
    ],
    "configuration": {
      "title": "%config.title%",
      "properties": {
        "biTeamALTools.orgUrl": {
          "type": "string",
          "default": "",
          "description": "%config.orgUrl.description%"
        },
        "biTeamALTools.project": {
          "type": "string",
          "default": "",
          "description": "%config.project.description%"
        },
        "biTeamALTools.repository": {
          "type": "string",
          "default": "",
          "description": "%config.repository.description%"
        },
        "biTeamALTools.folders": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            ".claude",
            ".github"
          ],
          "description": "%config.folders.description%"
        },
        "biTeamALTools.autoDownloadOnOpen": {
          "type": "boolean",
          "default": false,
          "description": "%config.autoDownloadOnOpen.description%"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.9"
  }
}
